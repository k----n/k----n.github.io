{
  "name": "k----n.github.io",
  "version": "1.0.0",
  "private": true,
  "description": "Academic personal website",
  "scripts": {
    "clean": "rimraf dist",
    "copy:assets": "copyfiles -u 0 \"img/**/*\" \"fonts/**/*\" CNAME _headers dist",
    "minify:html": "html-minifier-terser --collapse-whitespace --remove-comments --minify-css true --minify-js true -o dist/index.html index.html",
    "build": "npm run clean && npm run copy:assets && npm run minify:html",
    "preview": "npx serve dist"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "copyfiles": "^2.4.1",
    "html-minifier-terser": "^7.2.0",
    "rimraf": "^5.0.7"
  }
}
